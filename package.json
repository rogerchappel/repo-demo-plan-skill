{
  "name": "repo-demo-plan-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill that turns repository evidence into a runnable demo plan.",
  "type": "module",
  "bin": {
    "repo-demo-plan": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/cli.js",
    "smoke": "node src/cli.js fixtures/sample-repo --evidence fixtures/evidence.json --format markdown",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "node scripts/package-smoke.js",
    "install:smoke": "node scripts/install-smoke.js",
    "release:check": "npm run validate && npm run package:smoke && npm run install:smoke"
  },
  "keywords": [
    "agent-skill",
    "demo",
    "repository",
    "launch"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repo-demo-plan-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repo-demo-plan-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/repo-demo-plan-skill#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "docs",
    "fixtures",
    "scripts",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ]
}
